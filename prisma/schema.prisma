// ReferBridge - Prisma Schema
// PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ENUMS

enum UserRole {
  CANDIDATE
  EMPLOYEE
  RECRUITER
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  REJECTED
  SUBMITTED
  INTERVIEWING
  OFFERED
  JOINED
  WITHDRAWN
}

enum JobStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum NotificationType {
  REFERRAL_REQUEST
  REFERRAL_ACCEPTED
  REFERRAL_REJECTED
  STATUS_UPDATE
  NEW_MESSAGE
  REWARD_UNLOCKED
}

enum RewardStatus {
  PENDING
  APPROVED
  PAID
}

// CORE USER TABLE

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  role          UserRole
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  fcmToken      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidate     Candidate?
  employee      Employee?
  recruiter     Recruiter?
  refreshTokens RefreshToken[]
  sentMessages  Message[]        @relation("SentMessages")
  sentDirectMessages DirectMessage[] @relation("SentDirectMessages")
  notifications Notification[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// CANDIDATE PROFILE

model Candidate {
  id              String   @id @default(cuid())
  userId          String   @unique
  fullName        String
  avatarUrl       String?
  resumeUrl       String?
  headline        String?
  bio             String?
  skills          String[]
  experienceYears Int      @default(0)
  currentLocation String?
  preferredCities String[]
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  isOpenToWork    Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralRequests ReferralRequest[]
  directChats      DirectChat[]

  @@index([userId])
  @@index([skills])
  @@index([currentLocation])
  @@map("candidates")
}

// EMPLOYEE PROFILE

model Employee {
  id                  String   @id @default(cuid())
  userId              String   @unique
  fullName            String
  avatarUrl           String?
  companyId           String
  designation         String
  department          String?
  yearsAtCompany      Int      @default(0)
  linkedinUrl         String?
  isVerified          Boolean  @default(false)
  canRefer            Boolean  @default(true)
  totalReferrals      Int      @default(0)
  successfulReferrals Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          Company           @relation(fields: [companyId], references: [id])
  jobs             Job[]
  referralRequests ReferralRequest[]
  rewards          Reward[]

  @@index([userId])
  @@index([companyId])
  @@map("employees")
}

// RECRUITER PROFILE

model Recruiter {
  id          String   @id @default(cuid())
  userId      String   @unique
  fullName    String
  avatarUrl   String?
  companyId   String
  designation String?
  linkedinUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])
  jobs    Job[]
  directChats DirectChat[]
  referralRequests ReferralRequest[]

  @@index([userId])
  @@index([companyId])
  @@map("recruiters")
}

// COMPANY

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  logoUrl     String?
  website     String?
  industry    String?
  size        String?
  location    String?
  description String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees  Employee[]
  recruiters Recruiter[]
  jobs       Job[]

  @@index([name])
  @@map("companies")
}

// JOB POSTING

model Job {
  id             String    @id @default(cuid())
  employeeId     String?
  recruiterId    String?
  companyId      String
  title          String
  description    String
  requiredSkills String[]
  experienceMin  Int       @default(0)
  experienceMax  Int       @default(10)
  location       String
  isRemote       Boolean   @default(false)
  salaryMin      Int?
  salaryMax      Int?
  referralBonus  Int?
  openings       Int       @default(1)
  status         JobStatus @default(ACTIVE)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee         Employee?         @relation(fields: [employeeId], references: [id])
  recruiter        Recruiter?        @relation(fields: [recruiterId], references: [id])
  company          Company           @relation(fields: [companyId], references: [id])
  referralRequests ReferralRequest[]

  @@index([employeeId])
  @@index([companyId])
  @@index([requiredSkills])
  @@index([location])
  @@index([status])
  @@map("jobs")
}

// REFERRAL REQUEST

model ReferralRequest {
  id              String         @id @default(cuid())
  candidateId     String
  employeeId      String?
  jobId           String
  recruiterId     String?
  status          ReferralStatus @default(PENDING)
  coverNote       String?
  employeeNote    String?
  rejectionReason String?
  submittedAt     DateTime?
  joinedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  candidate Candidate  @relation(fields: [candidateId], references: [id])
  employee  Employee?  @relation(fields: [employeeId], references: [id])
  recruiter Recruiter? @relation(fields: [recruiterId], references: [id])
  job       Job        @relation(fields: [jobId], references: [id])
  chat      Chat?
  reward    Reward?

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([employeeId])
  @@index([recruiterId])
  @@index([jobId])
  @@index([status])
  @@map("referral_requests")
}

// CHAT (referral-based: candidate <-> employee)

model Chat {
  id                String   @id @default(cuid())
  referralRequestId String   @unique
  createdAt         DateTime @default(now())

  referralRequest ReferralRequest @relation(fields: [referralRequestId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@map("chats")
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation("SentMessages", fields: [senderId], references: [id])

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// DIRECT CHAT (recruiter <-> candidate, not tied to a referral)

model DirectChat {
  id          String   @id @default(cuid())
  recruiterId String
  candidateId String
  createdAt   DateTime @default(now())

  recruiter Recruiter       @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  messages  DirectMessage[]

  @@unique([recruiterId, candidateId])
  @@index([recruiterId])
  @@index([candidateId])
  @@map("direct_chats")
}

model DirectMessage {
  id           String   @id @default(cuid())
  directChatId String
  senderId     String
  content      String
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  directChat DirectChat @relation(fields: [directChatId], references: [id], onDelete: Cascade)
  sender     User       @relation("SentDirectMessages", fields: [senderId], references: [id])

  @@index([directChatId])
  @@index([senderId])
  @@index([createdAt])
  @@map("direct_messages")
}

// NOTIFICATIONS

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// REWARDS

model Reward {
  id                String       @id @default(cuid())
  employeeId        String
  referralRequestId String       @unique
  amount            Int
  status            RewardStatus @default(PENDING)
  approvedAt        DateTime?
  paidAt            DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  employee        Employee        @relation(fields: [employeeId], references: [id])
  referralRequest ReferralRequest @relation(fields: [referralRequestId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("rewards")
}
